{
  "name": "discord-ops",
  "version": "0.18.0",
  "description": "Agency-grade Discord MCP server with multi-guild project routing",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Booked Solid Technology",
    "url": "https://github.com/bookedsolidtech"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bookedsolidtech/discord-ops.git"
  },
  "bugs": {
    "url": "https://github.com/bookedsolidtech/discord-ops/issues"
  },
  "homepage": "https://github.com/bookedsolidtech/discord-ops#readme",
  "keywords": [
    "discord",
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "multi-guild",
    "devops",
    "notifications"
  ],
  "bin": {
    "discord-ops": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "node scripts/block-local-publish.mjs && npm run build",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "discord.js": "^14.18.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.1.2"
  },
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || ^24.0.0"
  }
}
